# Contraseña del panel de administración (/admin).
# Es una protección visual del lado del cliente: NO es seguridad real de producción.
# Para producción, mover la autenticación a un backend (Supabase Auth, Netlify Identity, etc.).
NEXT_PUBLIC_JENNIFER_ADMIN_PASS=jennifer2026

# URL pública del sitio (para SEO / Open Graph / sitemap).
NEXT_PUBLIC_SITE_URL=https://jennifermakeup.com.ar

# Google Analytics 4 / Google Ads (gtag). Dejar vacío para no cargar nada.
# Ej: G-XXXXXXX (GA4) o AW-XXXXXXXXX (Google Ads).
NEXT_PUBLIC_GTAG_ID=

# Label de conversión de Google Ads para el clic de WhatsApp.
# Ej: AW-XXXXXXXXX/AbC-D_efG. Se dispara como evento "conversion".
NEXT_PUBLIC_GADS_CONVERSION=
